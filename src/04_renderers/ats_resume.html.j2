<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <style>{{ css }}</style>
</head>
<body>
  <main class="page">
    <header class="header">
      <h1>{{ basics.name or 'Candidate Name' }}</h1>
      <p class="contact-line">
        {% if basics.email %}<span>{{ basics.email }}</span>{% endif %}
        {% if basics.phone %}<span>{{ basics.phone }}</span>{% endif %}
        {% if basics.location %}<span>{{ basics.location }}</span>{% endif %}
        {% if basics.linkedin %}<span>{{ basics.linkedin }}</span>{% endif %}
      </p>
    </header>

    {% if summary %}
    <section class="section">
      <h2>Professional Summary</h2>
      <p>{{ summary }}</p>
    </section>
    {% endif %}

    {% if skills %}
    <section class="section">
      <h2>Core Skills</h2>
      <div class="skills-grid">
        {% for skill in skills %}
        <span class="skill-item">{{ skill }}</span>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if experience_groups %}
    <section class="section">
      <h2>Relevant Experience</h2>
      {% for section_name, bullets in experience_groups.items() %}
      <article class="role-block">
        <h3>{{ section_name }}</h3>
        <ul>
          {% for bullet in bullets %}
          <li>{{ bullet.tailored_bullet }}</li>
          {% endfor %}
        </ul>
      </article>
      {% endfor %}
    </section>
    {% endif %}

    {% if keyword_coverage %}
    <section class="section">
      <h2>Keyword Alignment</h2>
      <p>{{ keyword_coverage | join(', ') }}</p>
    </section>
    {% endif %}

    {% if notes %}
    <section class="section notes">
      <h2>Reviewer Notes</h2>
      <ul>
        {% for note in notes %}
        <li>{{ note }}</li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  </main>
</body>
</html>